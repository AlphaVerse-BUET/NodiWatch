# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# Google Gemini API key (required for AI chatbot and image analysis)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: URL of deployed backend API (if using live OSM data)
# Default: not set (frontend uses static JSON files from src/data/)
NEXT_PUBLIC_API_URL=https://nodiwatch-api.onrender.com
