# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# Google Gemini API key (required for AI chatbot and image analysis)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Backend API URL — required for dynamic map data (real OSM rivers, factories, hotspots)
# Local development: http://localhost:8000
# Production (Render): https://nodiwatch-api.onrender.com
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Google Earth Engine Service Account Credentials (required for live satellite tiles)
# NEVER commit these to git! Stored securely on backend only.
# Get from: https://console.cloud.google.com/iam-admin/serviceaccounts (aquascaping-468411 project)
GEE_SERVICE_ACCOUNT_EMAIL=your_service_account@your-project.iam.gserviceaccount.com
GEE_PROJECT_ID=your-gcp-project-id
# Copy the entire private key string from the JSON, including \n line breaks
GEE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT\n-----END PRIVATE KEY-----\n"
